{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "edit": "ask",
    "task": "ask",
    "todowrite": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote -v": "allow",
      "git config --get*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "pwd": "allow",
      "echo*": "allow",
      "find*": "allow",
      "grep*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "which*": "allow",
      "*": "ask",
    },
  },

  "lsp": true,

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "<YOUR_CONTEXT7_API_KEY>",
      },
      "enabled": true,
    },
  },
}
